{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "CHANGE_ME_CONNECTION_STRING"
  },

  "SmtpSettings": {
    "Server": "smtp.gmail.com",
    "Port": 587,
    "SenderEmail": "CHANGE_ME_SMTP_SENDER",
    "Password": "CHANGE_ME_SMTP_PASSWORD"
  },

  "TokenOptions": {
    "SecurityKey": "CHANGE_ME_LONG_RANDOM_TOKEN_KEY_AT_LEAST_64_BYTES_FOR_PRODUCTION",
    "Issuer": "CHANGE_ME_ISSUER",
    "Audience": "CHANGE_ME_AUDIENCE",
    "AccessTokenExpiration": 60
  },
  "GoogleAuth": {
    "ClientIds": [
      "CHANGE_ME_GOOGLE_CLIENT_ID"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "https://evarkadasim.co",
      "https://www.evarkadasim.co",
      "http://localhost:3000",
      "http://localhost:19006",
      "http://localhost:8081"
    ]
  },
  "ReceiptOcr": {
    "OcrSpaceApiKey": "CHANGE_ME_OCR_API_KEY",
    "PythonServiceUrl": "http://127.0.0.1:8008"
  }
}
